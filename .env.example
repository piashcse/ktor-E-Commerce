# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ktor-ecom
DB_USER=postgres
DB_PASSWORD=change-me

# Server
PORT=8080
HOST=localhost

# JWT
JWT_SECRET=generate-a-secure-random-secret-at-least-256-bits-long
JWT_ISSUER=piashcse
JWT_AUDIENCE=ktor-ecommerce
JWT_REALM=ktor-ecommerce

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# Email (SMTP)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USERNAME=your-email@gmail.com
EMAIL_PASSWORD=your-app-password

# Uploads
UPLOAD_DIR=uploads

# Rate Limiting (format: limit:refillPeriodMinutes)
RATE_LIMIT_AUTH=5:10
RATE_LIMIT_OTP=10:10
RATE_LIMIT_REFRESH=10:10
RATE_LIMIT_WRITE=30:1
RATE_LIMIT_SEARCH=60:1
RATE_LIMIT_SELLER_WRITE=50:1
RATE_LIMIT_ADMIN_WRITE=100:1
RATE_LIMIT_GENERAL=100:1
